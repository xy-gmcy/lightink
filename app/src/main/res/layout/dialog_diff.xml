<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="48dp"
    android:layout_marginEnd="48dp"
    android:layout_marginBottom="48dp"
    android:background="@drawable/bg_dialog_round"
    android:orientation="vertical">

    <cn.lightink.reader.widget.BoldTextView
        android:id="@+id/mTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/margin_horizontal"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/mLocal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:padding="@dimen/padding">

            <TextView
                android:id="@+id/mLocalName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/mLocalVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/mLocalType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mImport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:padding="@dimen/padding">

            <TextView
                android:id="@+id/mImportName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/mImportVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/mImportType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_horizontal"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimenStroke"
        android:background="@color/colorStroke" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/mCancel"
            style="@style/Lightink.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/selected_btn_sign"
            android:padding="@dimen/padding"
            android:text="@string/cancel"
            android:textColor="@color/colorContent" />

        <View
            android:layout_width="@dimen/dimenStroke"
            android:layout_height="match_parent"
            android:background="@color/colorStroke" />

        <cn.lightink.reader.widget.BoldTextView
            android:id="@+id/mSubmit"
            style="@style/Lightink.Button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/selected_btn_sign"
            android:padding="@dimen/padding"
            android:text="@string/sure" />

    </LinearLayout>

</LinearLayout>